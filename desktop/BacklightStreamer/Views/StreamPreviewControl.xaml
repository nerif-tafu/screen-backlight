<UserControl x:Class="BacklightStreamer.Views.StreamPreviewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="80">
  <Grid>
    <Canvas x:Name="PreviewCanvas" Background="#1E293B" ClipToBounds="True"/>
    <TextBlock x:Name="PlaceholderText"
               Text="Yellow = inset boundary · blue bands = sample radius (px inward from inset)"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Foreground="#94A3B8"
               FontSize="13"
               TextAlignment="Center"
               Margin="16"/>
  </Grid>
</UserControl>
